<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_pose_dialog"
    android:padding="20dp">

    <ImageView
        android:id="@+id/iv_dialog_close"
        android:layout_width="19dp"
        android:layout_height="19dp"
        android:padding="2dp"
        android:src="@drawable/ic_close"
        app:tint="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_dialog_pose"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:layout_marginTop="7dp"
        app:layout_constraintDimensionRatio="169:237"
        app:layout_constraintTop_toBottomOf="@id/iv_dialog_close"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_dialog_pose_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/suit_regular"
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/iv_dialog_pose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_dialog_star"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/iv_dialog_star"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:contentDescription="즐겨찾기"
        android:src="@drawable/ic_star_off"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_dialog_pose_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_dialog_pose_name" />

</androidx.constraintlayout.widget.ConstraintLayout>
