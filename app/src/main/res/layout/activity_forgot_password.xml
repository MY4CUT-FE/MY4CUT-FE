<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 뒤로가기 -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_arrow_back_24"
        android:padding="12dp"
        app:tint="@color/gray_900"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 타이틀 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:text="비밀번호 찾기"
        android:textColor="@color/gray_900"
        android:textSize="22sp"
        android:fontFamily="@font/suit_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back" />

    <!-- 이메일 라벨 -->
    <TextView
        android:id="@+id/tv_label_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginStart="20dp"
        android:text="이메일 (아이디)"
        android:textColor="@color/gray_900"
        android:textSize="12sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- 이메일 입력 + 인증코드 발송 버튼 -->
    <EditText
        android:id="@+id/et_email"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="이메일 입력"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/suit_regular"
        android:textColor="@color/gray_900"
        android:inputType="textEmailAddress"
        app:layout_constraintEnd_toStartOf="@id/btn_send_code"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_email" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_send_code"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="20dp"
        android:text="인증코드 발송"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:fontFamily="@font/suit_medium"
        android:stateListAnimator="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/coral_800"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/et_email"
        app:layout_constraintBottom_toBottomOf="@id/et_email" />

    <!-- 이메일 에러 메시지 -->
    <TextView
        android:id="@+id/tv_email_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="20dp"
        android:text="존재하지 않는 아이디입니다."
        android:textColor="@color/modal_red"
        android:textSize="11sp"
        android:fontFamily="@font/suit_regular"
        android:visibility="gone"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_email"
        tools:visibility="gone" />

    <!-- 인증코드 발송 안내 메시지 -->
    <TextView
        android:id="@+id/tv_send_guide"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="20dp"
        android:textColor="@color/gray_500"
        android:textSize="12sp"
        android:fontFamily="@font/suit_regular"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_email_error"
        tools:visibility="gone"
        tools:text="test@email.com으로 인증 코드를 발송했습니다.\n메일을 확인하고 인증코드 6자리를 입력해 주세요." />

    <!-- 인증코드 라벨 -->
    <TextView
        android:id="@+id/tv_label_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:text="인증코드"
        android:textColor="@color/gray_900"
        android:textSize="12sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_send_guide" />

    <!-- 인증코드 입력 -->
    <EditText
        android:id="@+id/et_code"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="인증코드 입력"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/suit_regular"
        android:textColor="@color/gray_900"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_code" />

    <!-- 인증코드 에러 메시지 -->
    <TextView
        android:id="@+id/tv_code_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="20dp"
        android:text="인증코드가 일치하지 않습니다."
        android:textColor="@color/modal_red"
        android:textSize="11sp"
        android:fontFamily="@font/suit_regular"
        android:visibility="gone"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_code"
        tools:visibility="gone" />

    <!-- 확인 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="32dp"
        android:text="확인"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/suit_bold"
        android:stateListAnimator="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/coral_800"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
