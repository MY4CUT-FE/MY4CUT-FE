<?xml version="1.0" encoding="utf-8"?>
<!-- [수정] BottomSheetDialog용 레이아웃: rounded dialog bg 제거, 아이콘 지원 추가 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="32dp">

    <!-- 타이틀 -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="비밀번호 변경하기"
        android:textColor="@color/gray_900"
        android:textSize="18sp"
        android:fontFamily="@font/suit_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_close"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 닫기 버튼 -->
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_close"
        app:tint="@color/gray_900"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_dialog_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_dialog_title" />

    <!-- 새 비밀번호 라벨 -->
    <TextView
        android:id="@+id/tv_label_new_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="새 비밀번호"
        android:textColor="@color/gray_900"
        android:textSize="12sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_title" />

    <!-- 새 비밀번호 입력 -->
    <EditText
        android:id="@+id/et_new_password"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="비밀번호 입력"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/suit_regular"
        android:textColor="@color/gray_900"
        android:inputType="textPassword"
        android:drawableEnd="@drawable/ic_visibility_off"
        android:drawableTint="@color/gray_500"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_new_password" />

    <!-- 새 비밀번호 에러 메시지 (아이콘은 코드에서 동적으로 설정) -->
    <TextView
        android:id="@+id/tv_new_password_error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/modal_red"
        android:textSize="11sp"
        android:fontFamily="@font/suit_regular"
        android:visibility="gone"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_new_password" />

    <!-- 비밀번호 재입력 라벨 -->
    <TextView
        android:id="@+id/tv_label_confirm_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="비밀번호 재입력"
        android:textColor="@color/gray_900"
        android:textSize="12sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_new_password_error" />

    <!-- 비밀번호 재입력 -->
    <EditText
        android:id="@+id/et_confirm_password"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="비밀번호 재입력"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/suit_regular"
        android:textColor="@color/gray_900"
        android:inputType="textPassword"
        android:drawableEnd="@drawable/ic_visibility_off"
        android:drawableTint="@color/gray_500"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_confirm_password" />

    <!-- 비밀번호 불일치 에러 메시지 (아이콘은 코드에서 동적으로 설정) -->
    <TextView
        android:id="@+id/tv_confirm_password_error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/modal_red"
        android:textSize="11sp"
        android:fontFamily="@font/suit_regular"
        android:visibility="gone"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_confirm_password" />

    <!-- 변경 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_change"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="변경"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/suit_bold"
        android:stateListAnimator="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/coral_800"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_confirm_password_error" />

</androidx.constraintlayout.widget.ConstraintLayout>
