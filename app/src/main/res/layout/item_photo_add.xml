<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_add_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#D9D9D9"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!--
            [핵심 수정] layout_gravity="center" → "start|center_vertical"
            이유: ViewPager paddingHorizontal=40dp일 때 다음 카드의 좌측 40dp만 peek으로 노출됨.
            center 배치 시 아이콘이 카드 중앙(~120dp)에 위치해 40dp peek 영역 밖에 있어 보이지 않음.
            start 배치 + marginStart=4dp → 아이콘 범위(4~33dp)가 peek 영역(0~36dp) 안에 완전히 포함됨.
        -->
        <ImageView
            android:id="@+id/iv_add_icon"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="12dp"
            android:src="@drawable/btn_upload_photo"
            android:scaleType="fitCenter"/>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
