<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_intro_gradient">

    <!-- 로고 텍스트 (상단) -->
    <TextView
        android:id="@+id/tv_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="MY4CUT"
        android:textColor="@color/coral_900"
        android:textSize="40sp"
        android:fontFamily="@font/hakgyoansim_ttwimteul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_sub_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Scrap Your Memories"
        android:textColor="@color/coral_800"
        android:textSize="16sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_logo" />

    <!-- 중앙 일러스트 컨테이너 -->
    <FrameLayout
        android:id="@+id/fl_illustration_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/tv_start_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.591"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_sub_logo"
        app:layout_constraintVertical_bias="0.48">

        <ImageView
            android:id="@+id/iv_intro_illustration_1"
            android:layout_width="114dp"
            android:layout_height="286dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="9dp"
            android:layout_marginTop="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/intro_illustration_1" />

        <ImageView
            android:id="@+id/iv_intro_illustration_2"
            android:layout_width="157dp"
            android:layout_height="332dp"
            android:layout_gravity="end|top"
            android:layout_marginStart="90dp"
            android:layout_marginTop="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/intro_illustration_2" />

    </FrameLayout>

    <!-- 터치하여 시작하기 -->
    <TextView
        android:id="@+id/tv_start_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:text="터치하여 시작하기"
        android:textColor="@color/coral_800"
        android:textSize="16sp"
        android:fontFamily="@font/suit_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
